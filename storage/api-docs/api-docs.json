    "paths": {
        "/admin/login": {
            "post": {
                "tags": [
                    "Admin"
                ],
                "summary": "Realiza o login do administrador",
                "operationId": "5a44a85b9dc2cd4c50f1adf5b9b1095a",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nome_usuario",
                                    "password"
                                ],
                                "properties": {
                                    "nome_usuario": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redireciona para o dashboard admin"
                    },
                    "401": {
                        "description": "Credenciais inválidas"
                    }
                }
            }
        },
        "/dashboard/dados-graficos": {
            "get": {
                "tags": [
                    "Admin"
                ],
                "summary": "Retorna os dados para os gráficos do dashboard admin",
                "operationId": "81c244fbf97a420d4dbbb1db8e6baf3c",
                "responses": {
                    "200": {
                        "description": "Dados dos gráficos",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "labels": {
                                            "type": "array",
                                            "items": {
                                                "type": "integer"
                                            }
                                        },
                                        "usuarios": {
                                            "type": "array",
                                            "items": {
                                                "type": "integer"
                                            }
                                        },
                                        "fornecedores": {
                                            "type": "array",
                                            "items": {
                                                "type": "integer"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
