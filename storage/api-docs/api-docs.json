                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "telefone": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    },
                                    "foto": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redireciona para o login de fornecedores"
                    }
                }
            }
        },
        "/fornecedores/login": {
            "post": {
                "tags": [
                    "Fornecedores"
                ],
                "summary": "Realiza o login do fornecedor",
