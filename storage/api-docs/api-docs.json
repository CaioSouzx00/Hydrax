                "operationId": "7c0a75f3bcd80c4d63d7d6904fb94c52",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "nome_empresa",
                                    "cnpj",
                                    "email",
                                    "telefone",
                                    "password"
                                ],
                                "properties": {
                                    "nome_empresa": {
                                        "type": "string"
